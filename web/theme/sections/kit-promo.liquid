<style>
  .nc-kit {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
  }

  .nc-kit__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }

  .nc-kit__badge {
    display: inline-block;
    background: {{ section.settings.accent_color }};
    color: #1C2B1A;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 16px;
  }

  .nc-kit__title {
    color: {{ section.settings.text_color }};
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 12px;
  }

  .nc-kit__subtitle {
    color: {{ section.settings.text_color }};
    font-size: 16px;
    opacity: 0.75;
    line-height: 1.6;
    margin: 0 0 28px;
    max-width: 440px;
  }

  .nc-kit__items-label {
    color: {{ section.settings.accent_color }};
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 14px;
  }

  .nc-kit__items {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 16px;
    margin: 0 0 32px;
    padding: 0;
    list-style: none;
  }

  .nc-kit__item {
    color: {{ section.settings.text_color }};
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    line-height: 1.4;
  }

  .nc-kit__item-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: {{ section.settings.accent_color }};
    flex-shrink: 0;
  }

  .nc-kit__note {
    font-size: 12px;
    color: {{ section.settings.text_color }};
    opacity: 0.5;
    margin: -20px 0 24px;
    font-style: italic;
  }

  .nc-kit__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: {{ section.settings.accent_color }};
    color: #1C2B1A;
    font-size: 15px;
    font-weight: 800;
    padding: 14px 28px;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.15s, transform 0.15s;
  }

  .nc-kit__cta:hover {
    opacity: 0.88;
    transform: translateY(-1px);
    color: #1C2B1A;
    text-decoration: none;
  }

  .nc-kit__image-wrap {
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 4/5;
    background: rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nc-kit__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .nc-kit__image-placeholder {
    font-size: 80px;
    opacity: 0.3;
  }

  @media (max-width: 768px) {
    .nc-kit__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .nc-kit__image-wrap {
      aspect-ratio: 16/9;
      order: -1;
    }
    .nc-kit__items {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="nc-kit">
  <div class="nc-kit__inner">

    <div class="nc-kit__image-wrap">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 900 }}"
          alt="{{ section.settings.title }}"
          width="900"
          loading="lazy"
        >
      {% elsif section.settings.image_url != blank %}
        <img
          src="{{ section.settings.image_url }}"
          alt="{{ section.settings.title }}"
          width="900"
          loading="lazy"
        >
      {% else %}
        <div class="nc-kit__image-placeholder">🧼</div>
      {% endif %}
    </div>

    <div class="nc-kit__content">
      <div class="nc-kit__badge">{{ section.settings.badge }}</div>
      <h2 class="nc-kit__title">{{ section.settings.title }}</h2>
      <p class="nc-kit__subtitle">{{ section.settings.subtitle }}</p>

      <p class="nc-kit__items-label">Incluye en cada kit:</p>
      <ul class="nc-kit__items">
        {% for block in section.blocks %}
          {% if block.type == 'item' and block.settings.label != blank %}
            <li class="nc-kit__item" {{ block.shopify_attributes }}>
              <span class="nc-kit__item-dot"></span>
              {{ block.settings.label }}
            </li>
          {% endif %}
        {% endfor %}
      </ul>

      {% if section.settings.note != blank %}
        <p class="nc-kit__note">* {{ section.settings.note }}</p>
      {% endif %}

      <a
        href="{{ section.settings.cta_url }}"
        class="nc-kit__cta"
        {% if section.settings.cta_new_tab %}target="_blank" rel="noopener"{% endif %}
      >
        {{ section.settings.cta_icon }} {{ section.settings.cta_label }}
      </a>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Kit Promocional",
  "tag": "section",
  "class": "nc-kit-section",
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen del kit"
    },
    {
      "type": "text",
      "id": "image_url",
      "label": "URL imagen (alternativo)"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Etiqueta superior",
      "default": "Nuevo"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Kit de Jabón Artesanal"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Descripción",
      "default": "Todo lo que necesitas para crear tus primeros jabones artesanales en casa. Fórmula lista para usar."
    },
    {
      "type": "text",
      "id": "note",
      "label": "Nota al pie (opcional)",
      "default": "Fragancia según disponibilidad: vainilla, pomelo o aloe vera."
    },
    {
      "type": "header",
      "content": "Botón CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón",
      "default": "Pedir por WhatsApp"
    },
    {
      "type": "text",
      "id": "cta_icon",
      "label": "Emoji / ícono",
      "default": "💬"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del botón"
    },
    {
      "type": "checkbox",
      "id": "cta_new_tab",
      "label": "Abrir en nueva pestaña",
      "default": true
    },
    {
      "type": "header",
      "content": "Colores y espaciado"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo",
      "default": "#1C2B1A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texto",
      "default": "#F5F0E8"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Acento",
      "default": "#C4A45E"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Espaciado superior (px)",
      "default": 72
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Espaciado inferior (px)",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item del kit",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Descripción del item",
          "default": "Ingrediente"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kit Promocional",
      "settings": {
        "badge": "Kit Artesanal",
        "title": "Kit de Jabón Artesanal",
        "subtitle": "Todo lo que necesitas para crear tus primeros jabones en casa. Ingredientes de calidad, resultados profesionales.",
        "note": "Fragancia según disponibilidad: vainilla, pomelo o aloe vera.",
        "cta_label": "Pedir por WhatsApp",
        "cta_icon": "💬",
        "cta_new_tab": true
      },
      "blocks": [
        { "type": "item", "settings": { "label": "Alcohol 250ml" } },
        { "type": "item", "settings": { "label": "Aceite de coco 120ml" } },
        { "type": "item", "settings": { "label": "Vitamina E 30ml" } },
        { "type": "item", "settings": { "label": "Extracto de arroz" } },
        { "type": "item", "settings": { "label": "Extracto de avena" } },
        { "type": "item", "settings": { "label": "Fragancia para jabón" } },
        { "type": "item", "settings": { "label": "Pipetas plásticas x2" } },
        { "type": "item", "settings": { "label": "Vaso medidor 100ml" } },
        { "type": "item", "settings": { "label": "Termómetro digital" } },
        { "type": "item", "settings": { "label": "Espátula de silicona" } },
        { "type": "item", "settings": { "label": "Molde silicona 6 cavidades" } },
        { "type": "item", "settings": { "label": "Bolsa zip" } }
      ]
    }
  ]
}
{% endschema %}
