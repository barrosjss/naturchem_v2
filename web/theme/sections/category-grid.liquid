<style>
  .nc-cats {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
  }

  .nc-cats__head {
    text-align: center;
    margin-bottom: 40px;
  }

  .nc-cats__label {
    display: inline-block;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #2D5A27;
    margin-bottom: 10px;
  }

  .nc-cats__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(24px, 3.5vw, 38px);
    color: #1C2B1A;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }

  .nc-cats__grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .nc-cats__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: #fff;
    border: 1.5px solid #E8E2D9;
    border-radius: 14px;
    padding: 28px 16px 24px;
    text-decoration: none;
    transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
    cursor: pointer;
  }

  .nc-cats__card:hover {
    border-color: #C4A45E;
    box-shadow: 0 4px 20px rgba(28, 43, 26, 0.10);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .nc-cats__icon {
    font-size: 36px;
    margin-bottom: 12px;
    line-height: 1;
  }

  .nc-cats__name {
    font-size: 14px;
    font-weight: 700;
    color: #1C2B1A;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .nc-cats__count {
    font-size: 12px;
    color: #2D5A27;
    opacity: 0.7;
    margin: 0;
  }

  @media (max-width: 900px) {
    .nc-cats__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .nc-cats__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    .nc-cats__card {
      padding: 20px 12px 18px;
    }
    .nc-cats__icon {
      font-size: 28px;
    }
  }
</style>

<div class="nc-cats">
  <div class="nc-cats__head">
    {% if section.settings.label != blank %}
      <p class="nc-cats__label">{{ section.settings.label }}</p>
    {% endif %}
    <h2 class="nc-cats__title">{{ section.settings.title }}</h2>
  </div>

  <div class="nc-cats__grid">
    {% for block in section.blocks %}
      <a
        href="{{ block.settings.url | default: '/collections/all' }}"
        class="nc-cats__card"
        {{ block.shopify_attributes }}
      >
        <div class="nc-cats__icon">{{ block.settings.icon }}</div>
        <p class="nc-cats__name">{{ block.settings.name }}</p>
        {% if block.settings.count != blank %}
          <p class="nc-cats__count">{{ block.settings.count }}</p>
        {% endif %}
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Categorías",
  "tag": "section",
  "class": "nc-category-grid",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta superior",
      "default": "Catálogo"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Explora nuestras categorías"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo",
      "default": "#F5F0E8"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Espaciado superior (px)",
      "default": 64
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Espaciado inferior (px)",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoría",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji / ícono",
          "default": "🌿"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre",
          "default": "Categoría"
        },
        {
          "type": "text",
          "id": "count",
          "label": "Subtítulo (ej: 272 productos)"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Enlace"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categorias",
      "blocks": [
        { "type": "category", "settings": { "icon": "C1", "name": "Envases y Moldes", "count": "272 productos" } },
        { "type": "category", "settings": { "icon": "C2", "name": "Fragancias", "count": "92 productos" } },
        { "type": "category", "settings": { "icon": "C3", "name": "Colorantes", "count": "48 productos" } },
        { "type": "category", "settings": { "icon": "C4", "name": "Aceites y Extractos", "count": "40 productos" } },
        { "type": "category", "settings": { "icon": "C5", "name": "Materias Primas", "count": "36 productos" } },
        { "type": "category", "settings": { "icon": "C6", "name": "Ingredientes", "count": "29 productos" } },
        { "type": "category", "settings": { "icon": "C7", "name": "Bases y Ceras", "count": "24 productos" } },
        { "type": "category", "settings": { "icon": "C8", "name": "Insumos", "count": "21 productos" } }
      ]
    }
  ]
}
{% endschema %}
